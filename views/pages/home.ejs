<%- include('../partials/header') %>

<% 
const getPlatformIcon = (slug) => {
  switch (slug) {
    case 'pc':          return 'bi-windows';
    case 'playstation': return 'bi-playstation';
    case 'xbox':        return 'bi-xbox';
    case 'nintendo':    return 'bi-dpad-fill';
    case 'android':     return 'bi-android2';
    case 'ios':         return 'bi-apple';
    default:            return 'bi-controller';
  }
};

const getMetaClass = (score) => {
  if (!score) return '';
  if (score >= 80) return 'meta-badge-high';
  if (score >= 50) return 'meta-badge-mid';
  return 'meta-badge-low';
};

const formatDate = (dateStr) => {
  if (!dateStr) return 'TBA';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const filteredFeatured   = (featured    || []).filter(g => g.parent_platforms?.length > 0);
const filteredNewReleases= (newReleases || []).filter(g => g.parent_platforms?.length > 0);
const filteredUpcoming   = (upcoming    || []).filter(g => g.parent_platforms?.length > 0);
const filteredGames      = (games       || []).filter(g => g.parent_platforms?.length > 0);
%>

<!-- ═══════════════ FEATURED CAROUSEL ═══════════════ -->
<% if (filteredFeatured.length > 0) { %>
<div class="carousel-section">
  <div id="featuredCarousel"
       class="carousel slide carousel-fade"
       data-bs-ride="carousel"
       data-bs-interval="5000"
       data-bs-pause="hover">

    <div class="carousel-indicators">
      <% filteredFeatured.forEach((_, i) => { %>
        <button type="button"
                data-bs-target="#featuredCarousel"
                data-bs-slide-to="<%= i %>"
                class="<%= i === 0 ? 'active' : '' %>"></button>
      <% }) %>
    </div>

    <div class="carousel-inner">
      <% filteredFeatured.forEach((game, i) => { %>
        <div class="carousel-item <%= i === 0 ? 'active' : '' %>">
          <div class="hero-banner">

            <img src="<%= game.background_image %>"
                 class="hero-img"
                 alt="<%= game.name %>">

            <div class="hero-overlay">
              <div class="hero-content">

                <div class="hero-eyebrow">
                  <i class="bi bi-fire"></i> Featured
                </div>

                <h1 class="hero-title"><%= game.name %></h1>

                <div class="hero-meta">
                  <% if (game.metacritic) { %>
                    <span class="meta-badge meta-badge-hero <%= getMetaClass(game.metacritic) %>">
                      MC <%= game.metacritic %>
                    </span>
                  <% } %>
                  <span class="hero-rating">
                    <i class="bi bi-star-fill"></i>
                    <%= game.rating ? game.rating.toFixed(1) : 'N/A' %>
                  </span>
                  <span class="hero-date"><%= formatDate(game.released) %></span>
                </div>

                <div class="hero-platforms">
                  <% game.parent_platforms.forEach(p => { %>
                    <span class="genre-tag">
                      <i class="<%= getPlatformIcon(p.platform.slug) %> me-1"></i><%= p.platform.name %>
                    </span>
                  <% }) %>
                </div>

                <button class="hero-cta bookmark-btn"
                        style="position:static; width:auto; height:auto; border-radius:12px; font-size:0.9rem; padding:0.7rem 1.5rem; backdrop-filter:none;"
                        data-id="<%= game.id %>"
                        data-name="<%= game.name %>"
                        data-image="<%= game.background_image %>">
                  <i class="bi bi-bookmark-plus me-1"></i> Add to Backlog
                </button>

              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>

    <button class="carousel-control-prev" type="button"
            data-bs-target="#featuredCarousel" data-bs-slide="prev">
      <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button"
            data-bs-target="#featuredCarousel" data-bs-slide="next">
      <span class="carousel-control-next-icon"></span>
    </button>

  </div>
</div>
<% } %>

<!-- ═══════════════ PAGE CONTENT ═══════════════ -->
<div class="page-content mt-5">

  <!-- New Releases -->
  <div class="section-header">
    <div class="section-label">
      <h2 class="section-title">New Releases</h2>
    </div>
    <span class="section-sub">Recently launched</span>
  </div>

  <div class="scroll-container mb-5">
    <% filteredNewReleases.forEach(game => { %>
      <div class="game-card flex-shrink-0" style="width:230px;">
        <div class="card-img-wrapper" style="height:136px;">
          <% if (game.metacritic) { %>
            <div class="card-badge-overlay">
              <span class="meta-badge <%= getMetaClass(game.metacritic) %>"><%= game.metacritic %></span>
            </div>
          <% } %>
          <button class="bookmark-btn"
                  data-id="<%= game.id %>"
                  data-name="<%= game.name %>"
                  data-image="<%= game.background_image %>">
            <i class="bi bi-bookmark-plus"></i>
          </button>
          <img src="<%= game.background_image %>" class="card-img-top h-100" alt="<%= game.name %>">
        </div>
        <div class="card-body">
          <div class="platform-row">
            <div class="platform-icons">
              <% (game.parent_platforms || []).slice(0, 4).forEach(p => { %>
                <i class="<%= getPlatformIcon(p.platform.slug) %> platform-icon" title="<%= p.platform.name %>"></i>
              <% }) %>
            </div>
          </div>
          <h6 class="game-title" title="<%= game.name %>"><%= game.name %></h6>
          <div class="card-stats">
            <span class="star-rating">
              <i class="bi bi-star-fill"></i>
              <%= game.rating ? game.rating.toFixed(1) : 'N/A' %>
            </span>
            <span class="playtime-badge"><%= formatDate(game.released) %></span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Coming Soon -->
  <div class="section-header">
    <div class="section-label">
      <h2 class="section-title">Coming Soon</h2>
    </div>
    <span class="section-sub">Upcoming releases</span>
  </div>

  <div class="scroll-container mb-5">
    <% filteredUpcoming.forEach(game => { %>
      <div class="game-card flex-shrink-0" style="width:230px;">
        <div class="card-img-wrapper" style="height:136px;">
          <button class="bookmark-btn"
                  data-id="<%= game.id %>"
                  data-name="<%= game.name %>"
                  data-image="<%= game.background_image %>">
            <i class="bi bi-bookmark-plus"></i>
          </button>
          <img src="<%= game.background_image || '/images/placeholder.jpg' %>"
               class="card-img-top h-100" alt="<%= game.name %>">
        </div>
        <div class="card-body">
          <div class="platform-row">
            <div class="platform-icons">
              <% (game.parent_platforms || []).slice(0, 4).forEach(p => { %>
                <i class="<%= getPlatformIcon(p.platform.slug) %> platform-icon" title="<%= p.platform.name %>"></i>
              <% }) %>
            </div>
          </div>
          <h6 class="game-title" title="<%= game.name %>"><%= game.name %></h6>
          <div class="card-stats">
            <span class="upcoming-date">
              <i class="bi bi-calendar3"></i>
              <%= formatDate(game.released) %>
            </span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Popular Games -->
  <div class="section-header mb-2">
    <div class="section-label">
      <h2 class="section-title">Popular Games</h2>
    </div>
    <span class="section-sub">Browse the catalog</span>
  </div>

  <!-- Search + Filter -->
  <div class="filter-bar">
    <div class="search-wrapper">
      <i class="bi bi-search search-icon"></i>
      <input type="text"
             id="gameSearch"
             class="search-control"
             placeholder="Search games…"
             autocomplete="off">
    </div>
    <div class="filter-pills" id="filterPills">
      <button class="filter-pill active" data-genre="all">All</button>
      <button class="filter-pill" data-genre="action">Action</button>
      <button class="filter-pill" data-genre="rpg">RPG</button>
      <button class="filter-pill" data-genre="shooter">Shooter</button>
      <button class="filter-pill" data-genre="adventure">Adventure</button>
      <button class="filter-pill" data-genre="puzzle">Puzzle</button>
      <button class="filter-pill" data-genre="racing">Racing</button>
      <button class="filter-pill" data-genre="sports">Sports</button>
      <button class="filter-pill" data-genre="strategy">Strategy</button>
      <button class="filter-pill" data-genre="indie">Indie</button>
    </div>
  </div>

  <!-- Games Grid (horizontal scroll) -->
  <div class="scroll-container" id="gamesGrid">
    <% filteredGames.forEach(game => { %>
      <div class="game-item-card flex-shrink-0"
           style="width:230px;"
           data-title="<%= game.name.toLowerCase() %>"
           data-genres="<%= game.genres ? game.genres.map(g => g.slug).join(',') : '' %>"
           data-id="<%= game.id %>">
        <div class="game-card">
          <div class="card-img-wrapper" style="height:136px;">
            <% if (game.metacritic) { %>
              <div class="card-badge-overlay">
                <span class="meta-badge <%= getMetaClass(game.metacritic) %>"><%= game.metacritic %></span>
              </div>
            <% } %>
            <button class="bookmark-btn"
                    data-id="<%= game.id %>"
                    data-name="<%= game.name %>"
                    data-image="<%= game.background_image %>">
              <i class="bi bi-bookmark-plus"></i>
            </button>
            <img src="<%= game.background_image %>"
                 class="card-img-top h-100"
                 alt="<%= game.name %>">
          </div>
          <div class="card-body">
            <div class="platform-row">
              <div class="platform-icons">
                <% if (game.parent_platforms) { %>
                  <% game.parent_platforms.slice(0, 4).forEach(p => { %>
                    <i class="<%= getPlatformIcon(p.platform.slug) %> platform-icon" title="<%= p.platform.name %>"></i>
                  <% }) %>
                <% } %>
              </div>
              <% if (game.released) { %>
                <span class="release-year"><%= new Date(game.released).getFullYear() %></span>
              <% } %>
            </div>
            <h6 class="game-title" title="<%= game.name %>"><%= game.name %></h6>
            <div class="genre-tags">
              <% if (game.genres) { %>
                <% game.genres.slice(0, 2).forEach(genre => { %>
                  <span class="genre-tag"><%= genre.name %></span>
                <% }) %>
              <% } %>
            </div>
            <div class="card-stats">
              <span class="star-rating">
                <i class="bi bi-star-fill"></i>
                <%= game.rating ? game.rating.toFixed(2) : 'N/A' %>
              </span>
              <% if (game.playtime) { %>
                <span class="playtime-badge">
                  <i class="bi bi-clock"></i> <%= game.playtime %>h
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>

  <!-- Empty State -->
  <div id="noResults" class="d-none" style="text-align:center; padding:4rem 2rem;">
    <i class="bi bi-search" style="font-size:2.5rem; color:var(--text-muted); display:block; margin-bottom:1rem;"></i>
    <h4 style="font-size:1.05rem; font-weight:700; color:var(--text-primary); margin-bottom:0.4rem;">No games found</h4>
    <p style="font-size:0.85rem; color:var(--text-muted); margin:0;">Try a different search term or genre filter.</p>
  </div>

</div><!-- /.page-content -->

<!-- Toast -->
<div class="playnext-toast" id="backlogToast">
  <i class="bi bi-check-circle-fill" id="toastIcon"></i>
  <span id="toastMsg">Added to backlog</span>
</div>

<%- include('../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const searchInput  = document.getElementById('gameSearch');
  const filterPills  = document.querySelectorAll('.filter-pill');
  const gameItems    = document.querySelectorAll('.game-item-card');
  const noResults    = document.getElementById('noResults');

  let activeGenre = 'all';
  let searchQuery = '';

  const filterGames = () => {
    let count = 0;
    gameItems.forEach(item => {
      const title  = item.dataset.title || '';
      const genres = (item.dataset.genres || '').split(',');
      const show   = title.includes(searchQuery) &&
                     (activeGenre === 'all' || genres.includes(activeGenre));
      item.style.display = show ? 'block' : 'none';
      if (show) { item.classList.add('animate-fade-in'); count++; }
      else        item.classList.remove('animate-fade-in');
    });
    noResults.classList.toggle('d-none', count > 0);
  };

  if (searchInput) {
    searchInput.addEventListener('input', e => {
      searchQuery = e.target.value.toLowerCase().trim();
      filterGames();
    });
  }

  filterPills.forEach(pill => {
    pill.addEventListener('click', () => {
      filterPills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeGenre = pill.dataset.genre;
      filterGames();
    });
  });

  // ── Backlog ────────────────────────────────────
  const getBacklog  = () => JSON.parse(localStorage.getItem('playnext_backlog') || '[]');
  const saveBacklog = b  => localStorage.setItem('playnext_backlog', JSON.stringify(b));

  const showToast = (msg, success = true) => {
    const toast = document.getElementById('backlogToast');
    const icon  = document.getElementById('toastIcon');
    document.getElementById('toastMsg').textContent = msg;
    icon.className = success
      ? 'bi bi-check-circle-fill text-success'
      : 'bi bi-dash-circle-fill text-danger';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  };

  const syncBookmarks = () => {
    const ids = getBacklog().map(i => String(i.id));
    document.querySelectorAll('.bookmark-btn').forEach(btn => {
      const icon  = btn.querySelector('i');
      const saved = ids.includes(String(btn.dataset.id));
      btn.classList.toggle('active', saved);
      if (icon) icon.className = saved ? 'bi bi-bookmark-check-fill' : 'bi bi-bookmark-plus';
      btn.title = saved ? 'Remove from Backlog' : 'Add to Backlog';
    });
  };

  document.addEventListener('click', e => {
    const btn = e.target.closest('.bookmark-btn');
    if (!btn || !btn.dataset.id) return;
    e.preventDefault();

    const { id, name, image } = btn.dataset;
    let backlog = getBacklog();
    const exists = backlog.some(i => String(i.id) === String(id));

    if (exists) {
      backlog = backlog.filter(i => String(i.id) !== String(id));
      showToast(`Removed "${name}"`, false);
    } else {
      backlog.push({ id, name, image });
      showToast(`Added "${name}" to Backlog`);
    }

    saveBacklog(backlog);
    syncBookmarks();
  });

  syncBookmarks();
});
</script>
