<%- include('../partials/header') %>

<div class="auth-container d-flex justify-content-center align-items-center min-vh-100">

  <div class="auth-card p-4 rounded-4 shadow-lg">

    <h2 class="text-white mb-3 text-center">
      <span class="text-primary-neon">🎮</span> Login to PlayNext
    </h2>

    <p class="text-secondary text-center mb-4">
      Welcome back, gamer
    </p>

    <!-- Local Login Form -->
    <form action="/login" method="POST" class="mb-3">

      <div class="mb-3">
        <input type="email" name="email" class="form-control auth-input"
               placeholder="Email" required>
      </div>

      <div class="mb-3">
        <input type="password" name="password" class="form-control auth-input"
               placeholder="Password" required>
      </div>

      <button type="submit" class="btn btn-primary w-100 fw-semibold">
        Login
      </button>
    </form>

    <div class="text-center text-secondary mb-3">OR</div>

    <!-- Google Login -->
    <a href="/auth/google" class="btn btn-outline-light w-100 mb-3">
      <i class="bi bi-google me-2"></i> Continue with Google
    </a>

    <p class="text-center text-secondary small">
      Don't have an account?
      <a href="/register" class="text-primary-neon">Register</a>
    </p>

  </div>
</div>

<%- include('../partials/footer') %>