<%- include('../partials/header') %>

<%
const getPlatformIcon = (slug) => {
  switch (slug) {
    case 'pc':          return 'bi-windows';
    case 'playstation': return 'bi-playstation';
    case 'xbox':        return 'bi-xbox';
    case 'nintendo':    return 'bi-dpad-fill';
    case 'android':     return 'bi-android2';
    case 'ios':         return 'bi-apple';
    default:            return 'bi-controller';
  }
};

const getMetaClass = (score) => {
  if (!score) return '';
  if (score >= 80) return 'meta-badge-high';
  if (score >= 50) return 'meta-badge-mid';
  return 'meta-badge-low';
};

const formatDate = (dateStr) => {
  if (!dateStr) return 'TBA';
  return new Date(dateStr).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};

const allGames = (games || []).filter(g => g.parent_platforms?.length > 0);

const genres = [
  { slug: 'action',    label: 'Action' },
  { slug: 'rpg',       label: 'RPG' },
  { slug: 'shooter',   label: 'Shooter' },
  { slug: 'adventure', label: 'Adventure' },
  { slug: 'puzzle',    label: 'Puzzle' },
  { slug: 'racing',    label: 'Racing' },
  { slug: 'sports',    label: 'Sports' },
  { slug: 'strategy',  label: 'Strategy' },
  { slug: 'simulation',label: 'Simulation' },
  { slug: 'indie',     label: 'Indie' },
  { slug: 'casual',    label: 'Casual' },
  { slug: 'family',    label: 'Family' },
];

const platforms = [
  { slug: 'pc',          label: 'PC',          icon: 'bi-windows' },
  { slug: 'playstation', label: 'PlayStation',  icon: 'bi-playstation' },
  { slug: 'xbox',        label: 'Xbox',         icon: 'bi-xbox' },
  { slug: 'nintendo',    label: 'Nintendo',     icon: 'bi-dpad-fill' },
  { slug: 'ios',         label: 'iOS',          icon: 'bi-apple' },
  { slug: 'android',     label: 'Android',      icon: 'bi-android2' },
];
%>

<div class="games-page">

  <!-- ══ Sticky top bar ═══════════════════════════════════ -->
  <div class="games-topbar">
    <div class="games-topbar-inner">

      <div class="topbar-left">
        <h1 class="games-page-title">Browse Games</h1>
        <span class="games-count" id="resultCount"><%= allGames.length %> games</span>
      </div>

      <div class="topbar-right">
        <!-- Search -->
        <div class="search-wrapper">
          <i class="bi bi-search search-icon"></i>
<form action="/games/search" method="GET" class="search-wrapper">
  <i class="bi bi-search search-icon"></i>
  <input type="text"
         name="q"
         id="gameSearch"
         class="search-control"
         placeholder="Search by title…"
         value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
         autocomplete="off">
</form>
        </div>

        <!-- Sort -->
        <div class="sort-wrapper">
          <select id="sortSelect" class="sort-select">
            <option value="default">Sort: Default</option>
            <option value="rating-desc">Rating: High to Low</option>
            <option value="rating-asc">Rating: Low to High</option>
            <option value="meta-desc">Metacritic: High to Low</option>
            <option value="name-asc">Name: A – Z</option>
            <option value="name-desc">Name: Z – A</option>
            <option value="date-desc">Release: Newest</option>
            <option value="date-asc">Release: Oldest</option>
          </select>
          <i class="bi bi-chevron-down sort-chevron"></i>
        </div>

        <!-- View toggle -->
        <div class="view-toggle">
          <button class="view-btn active" id="gridViewBtn" title="Grid view">
            <i class="bi bi-grid-3x3-gap"></i>
          </button>
          <button class="view-btn" id="listViewBtn" title="List view">
            <i class="bi bi-list-ul"></i>
          </button>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ Layout: sidebar + grid ═══════════════════════════ -->
  <div class="games-layout">

    <!-- Sidebar -->
    <aside class="games-sidebar" id="gamesSidebar">

      <div class="sidebar-section">
        <p class="sidebar-label">Genre</p>
        <ul class="sidebar-list">
          <li>
            <button class="sidebar-btn active" data-filter="genre" data-value="all">
              All Genres
            </button>
          </li>
          <% genres.forEach(g => { %>
          <li>
            <button class="sidebar-btn" data-filter="genre" data-value="<%= g.slug %>">
              <%= g.label %>
            </button>
          </li>
          <% }) %>
        </ul>
      </div>

      <div class="sidebar-section">
        <p class="sidebar-label">Platform</p>
        <ul class="sidebar-list">
          <li>
            <button class="sidebar-btn active" data-filter="platform" data-value="all">
              All Platforms
            </button>
          </li>
          <% platforms.forEach(p => { %>
          <li>
            <button class="sidebar-btn" data-filter="platform" data-value="<%= p.slug %>">
              <i class="<%= p.icon %> me-1"></i> <%= p.label %>
            </button>
          </li>
          <% }) %>
        </ul>
      </div>

      <div class="sidebar-section">
        <p class="sidebar-label">Metacritic</p>
        <ul class="sidebar-list">
          <li><button class="sidebar-btn active" data-filter="meta" data-value="all">Any score</button></li>
          <li><button class="sidebar-btn" data-filter="meta" data-value="80">80+ — Must Play</button></li>
          <li><button class="sidebar-btn" data-filter="meta" data-value="70">70+ — Great</button></li>
          <li><button class="sidebar-btn" data-filter="meta" data-value="50">50+ — Mixed</button></li>
        </ul>
      </div>

      <button class="sidebar-reset" id="resetFilters">
        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset filters
      </button>

    </aside>

    <!-- Grid -->
    <main class="games-main">

      <div class="games-grid" id="gamesGrid">
        <% allGames.forEach(game => { %>
          <div class="game-item-card"
               data-title="<%= game.name.toLowerCase() %>"
               data-genres="<%= game.genres ? game.genres.map(g => g.slug).join(',') : '' %>"
               data-platforms="<%= game.parent_platforms ? game.parent_platforms.map(p => p.platform.slug).join(',') : '' %>"
               data-rating="<%= game.rating || 0 %>"
               data-meta="<%= game.metacritic || 0 %>"
               data-date="<%= game.released || '' %>"
               data-name-sort="<%= game.name.toLowerCase() %>">

            <div class="game-card">
              <div class="card-img-wrapper" style="height:148px;">
                <% if (game.metacritic) { %>
                  <div class="card-badge-overlay">
                    <span class="meta-badge <%= getMetaClass(game.metacritic) %>"><%= game.metacritic %></span>
                  </div>
                <% } %>
                <button class="bookmark-btn"
                        data-id="<%= game.id %>"
                        data-name="<%= game.name %>"
                        data-image="<%= game.background_image %>">
                  <i class="bi bi-bookmark-plus"></i>
                </button>
                <img src="<%= game.background_image %>"
                     class="card-img-top h-100"
                     alt="<%= game.name %>"
                     loading="lazy">
              </div>
              <div class="card-body">
                <div class="platform-row">
                  <div class="platform-icons">
                    <% if (game.parent_platforms) { %>
                      <% game.parent_platforms.slice(0, 4).forEach(p => { %>
                        <i class="<%= getPlatformIcon(p.platform.slug) %> platform-icon" title="<%= p.platform.name %>"></i>
                      <% }) %>
                    <% } %>
                  </div>
                  <% if (game.released) { %>
                    <span class="release-year"><%= new Date(game.released).getFullYear() %></span>
                  <% } %>
                </div>
                <h6 class="game-title" title="<%= game.name %>"><%= game.name %></h6>
                <div class="genre-tags">
                  <% if (game.genres) { %>
                    <% game.genres.slice(0, 2).forEach(genre => { %>
                      <span class="genre-tag"><%= genre.name %></span>
                    <% }) %>
                  <% } %>
                </div>
                <div class="card-stats">
                  <span class="star-rating">
                    <i class="bi bi-star-fill"></i>
                    <%= game.rating ? game.rating.toFixed(2) : 'N/A' %>
                  </span>
                  <% if (game.playtime) { %>
                    <span class="playtime-badge">
                      <i class="bi bi-clock"></i> <%= game.playtime %>h
                    </span>
                  <% } %>
                </div>
              </div>
            </div>

            <!-- List view row (hidden by default) -->
            <div class="list-card">
              <div class="list-card-thumb">
                <img src="<%= game.background_image %>" alt="<%= game.name %>" loading="lazy">
              </div>
              <div class="list-card-body">
                <div class="list-card-top">
                  <h6 class="list-card-title"><%= game.name %></h6>
                  <div class="list-card-genres">
                    <% if (game.genres) { %>
                      <% game.genres.slice(0, 3).forEach(genre => { %>
                        <span class="genre-tag"><%= genre.name %></span>
                      <% }) %>
                    <% } %>
                  </div>
                </div>
                <div class="list-card-meta">
                  <div class="platform-icons">
                    <% if (game.parent_platforms) { %>
                      <% game.parent_platforms.slice(0, 5).forEach(p => { %>
                        <i class="<%= getPlatformIcon(p.platform.slug) %> platform-icon" title="<%= p.platform.name %>"></i>
                      <% }) %>
                    <% } %>
                  </div>
                  <span class="list-card-date"><%= formatDate(game.released) %></span>
                  <span class="star-rating">
                    <i class="bi bi-star-fill"></i>
                    <%= game.rating ? game.rating.toFixed(2) : 'N/A' %>
                  </span>
                  <% if (game.metacritic) { %>
                    <span class="meta-badge <%= getMetaClass(game.metacritic) %>"><%= game.metacritic %></span>
                  <% } %>
                  <button class="bookmark-btn"
                          style="position:static; transform:none;"
                          data-id="<%= game.id %>"
                          data-name="<%= game.name %>"
                          data-image="<%= game.background_image %>">
                    <i class="bi bi-bookmark-plus"></i>
                  </button>
                </div>
              </div>
            </div>

          </div>
        <% }) %>
      </div>

      <!-- Empty state -->
      <div id="noResults" class="games-empty d-none">
        <i class="bi bi-search"></i>
        <h4>No games match your filters</h4>
        <p>Try adjusting the genre, platform, or search term.</p>
        <button class="sidebar-reset mt-3" id="resetFilters2">
          <i class="bi bi-arrow-counterclockwise me-1"></i> Reset filters
        </button>
      </div>

    </main>
  </div>
</div>

<!-- Toast -->
<div class="playnext-toast" id="backlogToast">
  <i class="bi bi-check-circle-fill" id="toastIcon"></i>
  <span id="toastMsg">Added to backlog</span>
</div>

<%- include('../partials/footer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {

  // ── State ──────────────────────────────────────────────
  let state = {
    search:   '',
    genre:    'all',
    platform: 'all',
    meta:     'all',
    sort:     'default',
    view:     'grid',   // 'grid' | 'list'
  };

  const allItems = Array.from(document.querySelectorAll('.game-item-card'));
  const grid     = document.getElementById('gamesGrid');
  const noRes    = document.getElementById('noResults');
  const countEl  = document.getElementById('resultCount');

  // ── Filter & Sort ──────────────────────────────────────
  const applyFilters = () => {
    let visible = [];

    allItems.forEach(item => {
      const title    = item.dataset.title || '';
      const genres   = (item.dataset.genres    || '').split(',');
      const platforms= (item.dataset.platforms || '').split(',');
      const rating   = parseFloat(item.dataset.rating) || 0;
      const meta     = parseInt(item.dataset.meta)     || 0;

      const okSearch   = !state.search   || title.includes(state.search);
      const okGenre    = state.genre    === 'all' || genres.includes(state.genre);
      const okPlatform = state.platform === 'all' || platforms.includes(state.platform);
      const okMeta     = state.meta     === 'all' || meta >= parseInt(state.meta);

      if (okSearch && okGenre && okPlatform && okMeta) {
        visible.push(item);
        item.style.display = '';
      } else {
        item.style.display = 'none';
      }
    });

    // Sort visible items
    const sorted = [...visible].sort((a, b) => {
      switch (state.sort) {
        case 'rating-desc': return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
        case 'rating-asc':  return parseFloat(a.dataset.rating) - parseFloat(b.dataset.rating);
        case 'meta-desc':   return parseInt(b.dataset.meta)     - parseInt(a.dataset.meta);
        case 'name-asc':    return a.dataset.nameSort.localeCompare(b.dataset.nameSort);
        case 'name-desc':   return b.dataset.nameSort.localeCompare(a.dataset.nameSort);
        case 'date-desc':   return new Date(b.dataset.date || 0) - new Date(a.dataset.date || 0);
        case 'date-asc':    return new Date(a.dataset.date || 0) - new Date(b.dataset.date || 0);
        default:            return 0;
      }
    });

    sorted.forEach(item => grid.appendChild(item));

    countEl.textContent = `${visible.length} game${visible.length !== 1 ? 's' : ''}`;
    noRes.classList.toggle('d-none', visible.length > 0);

    updateGenreCounts();
    syncBookmarks();
  };

  // ── Genre sidebar counts ───────────────────────────────
  const updateGenreCounts = () => {
    const genreSlugs = ['action','rpg','shooter','adventure','puzzle','racing','sports','strategy','simulation','indie','casual','family'];
    let allVisible = 0;

    allItems.forEach(item => {
      if (item.style.display !== 'none') allVisible++;
    });

    const allCountEl = document.getElementById('count-genre-all');
    if (allCountEl) allCountEl.textContent = allVisible;

    genreSlugs.forEach(slug => {
      const el = document.getElementById(`count-genre-${slug}`);
      if (!el) return;
      const n = allItems.filter(item => {
        if (item.style.display === 'none') return false;
        return (item.dataset.genres || '').split(',').includes(slug);
      }).length;
      el.textContent = n;
    });
  };

  // ── Search ─────────────────────────────────────────────
  const searchEl = document.getElementById('gameSearch');
  if (searchEl) {
    searchEl.addEventListener('input', e => {
      state.search = e.target.value.toLowerCase().trim();
      applyFilters();
    });
  }

  // ── Sort ───────────────────────────────────────────────
  const sortEl = document.getElementById('sortSelect');
  if (sortEl) {
    sortEl.addEventListener('change', e => {
      state.sort = e.target.value;
      applyFilters();
    });
  }

  // ── Sidebar filters ────────────────────────────────────
  document.querySelectorAll('.sidebar-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      const value  = btn.dataset.value;

      // Deactivate siblings in same group
      document.querySelectorAll(`.sidebar-btn[data-filter="${filter}"]`)
              .forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      state[filter] = value;
      applyFilters();
    });
  });

  // ── Reset ──────────────────────────────────────────────
  const resetAll = () => {
    state = { search: '', genre: 'all', platform: 'all', meta: 'all', sort: 'default', view: state.view };
    if (searchEl) searchEl.value = '';
    if (sortEl)   sortEl.value   = 'default';
    document.querySelectorAll('.sidebar-btn').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.value === 'all');
    });
    applyFilters();
  };

  document.getElementById('resetFilters')?.addEventListener('click', resetAll);
  document.getElementById('resetFilters2')?.addEventListener('click', resetAll);

  // ── View toggle ────────────────────────────────────────
  const gridViewBtn = document.getElementById('gridViewBtn');
  const listViewBtn = document.getElementById('listViewBtn');

  gridViewBtn?.addEventListener('click', () => {
    state.view = 'grid';
    grid.classList.remove('list-view');
    gridViewBtn.classList.add('active');
    listViewBtn.classList.remove('active');
  });

  listViewBtn?.addEventListener('click', () => {
    state.view = 'list';
    grid.classList.add('list-view');
    listViewBtn.classList.add('active');
    gridViewBtn.classList.remove('active');
  });

  // ── Backlog ────────────────────────────────────────────
  const getBacklog  = () => JSON.parse(localStorage.getItem('playnext_backlog') || '[]');
  const saveBacklog = b  => localStorage.setItem('playnext_backlog', JSON.stringify(b));

  const showToast = (msg, success = true) => {
    const toast = document.getElementById('backlogToast');
    const icon  = document.getElementById('toastIcon');
    document.getElementById('toastMsg').textContent = msg;
    icon.className = success
      ? 'bi bi-check-circle-fill text-success'
      : 'bi bi-dash-circle-fill text-danger';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 2500);
  };

  const syncBookmarks = () => {
    const ids = getBacklog().map(i => String(i.id));
    document.querySelectorAll('.bookmark-btn[data-id]').forEach(btn => {
      const icon  = btn.querySelector('i');
      const saved = ids.includes(String(btn.dataset.id));
      btn.classList.toggle('active', saved);
      if (icon) icon.className = saved ? 'bi bi-bookmark-check-fill' : 'bi bi-bookmark-plus';
      btn.title = saved ? 'Remove from Backlog' : 'Add to Backlog';
    });
  };

  document.addEventListener('click', e => {
    const btn = e.target.closest('.bookmark-btn[data-id]');
    if (!btn) return;
    e.preventDefault();
    const { id, name, image } = btn.dataset;
    let backlog = getBacklog();
    const exists = backlog.some(i => String(i.id) === String(id));
    if (exists) {
      backlog = backlog.filter(i => String(i.id) !== String(id));
      showToast(`Removed "${name}"`, false);
    } else {
      backlog.push({ id, name, image });
      showToast(`Added "${name}" to Backlog`);
    }
    saveBacklog(backlog);
    syncBookmarks();
  });

  // ── Init ───────────────────────────────────────────────
  applyFilters();
});
</script>
